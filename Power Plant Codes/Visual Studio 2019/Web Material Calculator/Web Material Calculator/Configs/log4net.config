<?xml version="1.0" encoding="utf-8"?>
<!-- Apache log4net™ Config Examples https://logging.apache.org/log4net/release/config-examples.html -->

<log4net>
<!-- Define some output appenders -->
  
  <!-- configure the RollingFileAppender to write to the file log.txt -->
	<appender name="rollingAppender" type="log4net.Appender.RollingFileAppender">
   
    <!--Log file path-->
    <file value="Log\PPWeb_log.txt" />
    
    <!--Append to same file-->
		<appendToFile value="true" />
		
    <!--use the minimal locking model that allows multiple processes to write to the same file-->
		<lockingModel type="log4net.Appender.FileAppender+MinimalLock" />

		<!--File rolling style: Once|Size|Date|Composite-->
		<!--Composite: roll log files on a date period and within a date period on file size-->
		<rollingStyle value="Composite" />

		<!--Rolling period. See System.Globalization.DateTimeFormatInfo for a list of available patterns-->
    <!--a date pattern of "yyyyMMdd" will roll every day-->
		<datePattern value="yyyyMMdd.TXT" />

		<!--Up to (MaxSizeRollBackups) old files of (MaximumFileSize) will be kept. -->
    <!--These rolled files will be named: log.txt.1, log.txt.2, log.txt.3, etc...-->
		<maxSizeRollBackups value="20" />

		<!--Available unit :KB|MB|GB-->
		<maximumFileSize value="3MB" />

		<!--The file will be rolled based on a size constraint-->
		<staticLogFileName value="true" />

		<!--Filters form a chain that the event has to pass through-->
		<filter type="log4net.Filter.LevelRangeFilter">
			<param name="LevelMin" value="ALL" />
			<param name="LevelMax" value="FATAL" />
		</filter>
    
    <!--Log pattern layout-->
		<layout type="log4net.Layout.PatternLayout">
			<conversionPattern value="%date [%thread] %-5level %logger - %message%newline"/>
		</layout>
    
	</appender>
	
  <root>
		<priority value="ALL"/>
		<level value="ALL"/>
		<appender-ref ref="rollingAppender" />
	</root>

</log4net>
