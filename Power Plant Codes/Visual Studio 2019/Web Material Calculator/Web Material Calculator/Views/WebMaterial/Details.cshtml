        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => webMaterialDto.Implength)
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Index">Back to Web Material List</a>
</div>

<!-- Display Table -->
<table class="table table-striped table-sm" style="table-layout:fixed">
    <thead align="center">
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Percentage)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RollDiameter)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Length)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Imps)
            </th>
        </tr>
    </thead>
    <tbody align="center">
        @foreach (PowerPlant.Dtos.WebMaterialLookupDto webMaterialLookupDto in ViewBag.WebMaterialLookupDtos)
        {
            @if (ViewBag.CalculatedRollDiameter == webMaterialLookupDto.RollDiameter)
            {
                <tr style="font-weight:bolder">
                    <td> @Html.DisplayFor(model => webMaterialLookupDto.Percentage) </td>
                    <td> @Html.DisplayFor(model => webMaterialLookupDto.RollDiameter) </td>
                    <td> @Html.DisplayFor(model => webMaterialLookupDto.Length) </td>
                    <td> @Html.DisplayFor(model => webMaterialLookupDto.Imps) </td>
                </tr>
            }
            else
            {
                <tr>
                    <td> @Html.DisplayFor(model => webMaterialLookupDto.Percentage) </td>
                    <td> @Html.DisplayFor(model => webMaterialLookupDto.RollDiameter) </td>
                    <td> @Html.DisplayFor(model => webMaterialLookupDto.Length) </td>
                    <td> @Html.DisplayFor(model => webMaterialLookupDto.Imps) </td>
                </tr>
            }
        }
    </tbody>
</table>