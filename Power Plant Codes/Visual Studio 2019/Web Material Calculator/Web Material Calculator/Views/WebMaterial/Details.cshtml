<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => webMaterialDto.ItemNumber)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => webMaterialDto.ItemNumber)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => webMaterialDto.ItemDescription)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => webMaterialDto.ItemDescription)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => webMaterialDto.CoreDiameter)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => webMaterialDto.CoreDiameter)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => webMaterialDto.RollDiameter)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => webMaterialDto.RollDiameter)
        </dd>
