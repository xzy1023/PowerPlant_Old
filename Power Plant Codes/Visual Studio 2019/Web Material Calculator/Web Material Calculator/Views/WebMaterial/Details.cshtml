@{
    @model PowerPlant.Dtos.WebMaterialLookupDto
    ViewData["Title"] = $"Details";
    PowerPlant.Dtos.WebMaterialDto webMaterialDto = ViewBag.WebMaterialDto as PowerPlant.Dtos.WebMaterialDto;
}

<h3>Details</h3>

<form asp-controller="WebMaterial" asp-action="Details" method="get">
    Remining Roll Diameter (mm)
    <input class="mr-3 ml-5" type="text" name="calculatedRollDiameter" value="@ViewBag.CalculatedRollDiameter" />
    <input hidden="hidden" type="text" name="rrn" value="@ViewBag.Rrn" />
    <input class="btn btn-info mr-3" type="submit" value="Calculate" />
</form>

