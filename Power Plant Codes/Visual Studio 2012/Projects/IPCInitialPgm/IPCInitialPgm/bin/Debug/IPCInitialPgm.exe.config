<?xml version="1.0"?>
<configuration>
    <configSections>
        <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
            <section name="IPCInitialPgm.My.MySettings" type="System.Configuration.ClientSettingsSection, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false"/>
        </sectionGroup>
    </configSections>
    <connectionStrings>
        <add name="IPCInitialPgm.My.MySettings.gstrServerCnnString" connectionString="Data Source=mphopp02;Initial Catalog=PowerPlantAXSP_Dev;Integrated Security=True"
            providerName="System.Data.SqlClient" />
        <add name="IPCInitialPgm.My.MySettings.gstrLocalCnnString" connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=LocalPowerPlant;Integrated Security=True"
            providerName="System.Data.SqlClient" />
        <add name="IPCInitialPgm.My.MySettings.gstrStagingCnnString"
            connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=ImportData;Integrated Security=True"
            providerName="System.Data.SqlClient" />
    </connectionStrings>
    <system.diagnostics>
        <sources>
            <!-- This section defines the logging configuration for My.Application.Log -->
            <source name="DefaultSource" switchName="DefaultSwitch">
                <listeners>
                    <add name="FileLog"/>
                    <!-- Uncomment the below section to write to the Application Event Log -->
                    <!--<add name="EventLog"/>-->
                </listeners>
            </source>
        </sources>
        <switches>
            <add name="DefaultSwitch" value="Information"/>
        </switches>
        <sharedListeners>
            <add name="FileLog" type="Microsoft.VisualBasic.Logging.FileLogTraceListener, Microsoft.VisualBasic, Version=8.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a, processorArchitecture=MSIL" initializeData="FileLogWriter"/>
            <!-- Uncomment the below section and replace APPLICATION_NAME with the name of your application to write to the Application Event Log -->
            <!--<add name="EventLog" type="System.Diagnostics.EventLogTraceListener" initializeData="APPLICATION_NAME"/> -->
        </sharedListeners>
    </system.diagnostics>
    <userSettings>
        <IPCInitialPgm.My.MySettings>
            <setting name="strDotNetPgm" serializeAs="String">
                <value>"C:\PowerPlant\PowerPlant\PowerPlant.exe"</value>
            </setting>
            <setting name="strInduSoftAppPgm" serializeAs="String">
                <value>C:\PowerPlant\Indusoft\PowerPlant.APP</value>
            </setting>
            <setting name="gstrDLDestination" serializeAs="String">
                <value>C:\PowerPlant\Downloads\Indusoft.zip</value>
            </setting>
            <setting name="gstrDLSource" serializeAs="String">
                <value>HTTP://MPSPPP01/Power Plant Downloads New/</value>
            </setting>
            <setting name="strInduSoftStartUpPgm" serializeAs="String">
                <value>C:\Program Files (x86)\InduSoft Web Studio v7.1\Bin\runstartup.exe</value>
            </setting>
            <setting name="gblnRefreshDB" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="gblnChgDftProfile" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="gblnCheckConfiguration" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="gstrNoIWSDftAccount" serializeAs="String">
                <value>2</value>
            </setting>
            <setting name="gstrIWSDftAccount" serializeAs="String">
                <value>5</value>
            </setting>
            <setting name="gstrPalletStationAccount" serializeAs="String">
                <value>3</value>
            </setting>
            <setting name="gstrIPCViewerAccount" serializeAs="String">
                <value>1</value>
            </setting>
            <setting name="gstrIPCViewerDLDestination" serializeAs="String">
                <value>C:\PowerPlant\Downloads\IPC.zip</value>
            </setting>
            <setting name="strIPCViewerPgm" serializeAs="String">
                <value>C:\IPC\IPC.bat</value>
            </setting>
        </IPCInitialPgm.My.MySettings>
    </userSettings>
<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5"/></startup></configuration>
