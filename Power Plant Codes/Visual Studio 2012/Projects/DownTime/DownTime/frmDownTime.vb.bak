        End Try
    End Sub
    Private Sub cboReasonCode_DropDown(ByVal sender As Object, ByVal e As System.EventArgs) Handles cboReasonCode.DropDown
        Try
            With cboReasonCode
                lblReasonCodeDesc.Visible = False
                'If the reason type is ALL, sort the list by reason code 
                If cboReasonType.SelectedValue = 0 Then
                    gtaDTReasonCode.Fill(gtblDTReasonCode, gstrMachineType, gstrFacility, gstrMachineSubType)
                Else
                    gtaDTReasonCode.FillByDescription(gtblDTReasonCode, gstrMachineType, cboReasonType.SelectedValue, gstrFacility, gstrMachineSubType)
                End If
                .DataSource = gtblDTReasonCode
                .DisplayMember = "Description"
                .ValueMember = "ReasonCode"
                .Font = New Font("Arial", 30, System.Drawing.FontStyle.Regular)
                .Width = 550
                gblnDropDownIsClicked = True
                gblnCancelComment = False             			'WO#3282
            End With
        Catch ex As System.Data.SqlClient.SqlException
            ChkErr(ex)
        Catch ex As Exception
            Throw New Exception("Error in cboReasonCode_DropDown" & Environment.NewLine & ex.Message)
        End Try
    End Sub
    Private Sub cboReasonCode_TextChanged(ByVal sender As Object, ByVal e As System.EventArgs) Handles cboReasonCode.TextChanged
        Dim intReasonCode As Short
        Dim tblDTReasonCode As New dsDTReasonCode.tblDTReasonCodeDataTable
        ' Dim strReasonCodeSave As String
        Dim strDisplayMemberSave As String                      'WO#3282
        Dim strSelectedValueSave As String                      'WO#3282
        Dim strSelectedTextSave As String                       'WO#3282
        Const cstDescription As String = "Description"          'WO#3282
        Const cstReasonCode As String = "ReasonCode"            'WO#3282

        Try
            gstrErrMsg = Nothing
    'WO#3282    If cboReasonCode.Text <> "" AndAlso IsNumeric(cboReasonCode.Text) _
    'WO#3282         AndAlso Not TypeOf (cboReasonCode.SelectedValue) Is DataRowView Then
            If (cboReasonCode.Text <> "" Or Not IsNothing(cboReasonCode.SelectedValue)) _
                AndAlso Not TypeOf (cboReasonCode.SelectedValue) Is DataRowView AndAlso gblnCancelComment = False Then

                If Not IsNumeric(cboReasonCode.Text) And Not IsNumeric(cboReasonCode.SelectedValue) Then
                    gstrErrMsg = "The Reason Code must be numeric."
                    MessageBox.Show(gstrErrMsg, "Invalid Information")
                    cboReasonCode.Focus()
                Else

                    If IsNumeric(cboReasonCode.Text) Then                   'WO#3282  
                        intReasonCode = cboReasonCode.Text                  'WO#3282
                        If cboReasonCode.DisplayMember <> cstReasonCode Then
                            strDisplayMemberSave = cstReasonCode			'WO#3282
                            strSelectedTextSave = cboReasonCode.Text
 							'WO#3282 cboReasonCode.DisplayMember = "ReasonCode"
                            cboReasonCode.DisplayMember = cstReasonCode		'WO#3282
                            cboReasonCode.Text = strSelectedTextSave		'WO#3282
                            If gblnCancelComment = True Then				'WO#3282
                                lblReasonCodeDesc.Text = ""					'WO#3282
                                cboReasonCode.Text = ""						'WO#3282
                                Exit Sub									'WO#3282
                            End If											'WO#3282
                        End If
					'WO#3282 ADD Start
                    Else        
                        intReasonCode = cboReasonCode.SelectedValue
                        If cboReasonCode.DisplayMember <> cstDescription Then
                            strDisplayMemberSave = cstDescription
                            strSelectedValueSave = cboReasonCode.SelectedValue
                            cboReasonCode.DisplayMember = cstDescription
                            If cboReasonCode.Text = "" And IsNothing(cboReasonCode.SelectedValue) Then
                                Exit Sub
                            End If
                            cboReasonCode.SelectedValue = strSelectedValueSave
                        End If
                    End If      
					'WO#3282 ADD Stop

                    'WO#3282    intReasonCode = cboReasonCode.Text

                    gtaDTReasonCode.FillByReasonCode(tblDTReasonCode, gstrMachineType, gstrMachineSubType, intReasonCode, gstrFacility)
                    If tblDTReasonCode.Rows.Count = 0 Then
                        lblReasonCodeDesc.Text = String.Empty
                        gstrErrMsg = "The Reason Code is not a valid code."
                        MessageBox.Show(gstrErrMsg, "Invalid Information")
                        cboReasonCode.Focus()
                    Else
                        lblReasonCodeDesc.Text = tblDTReasonCode.Rows(0)("Description")					'WO#3282
                        If cboReasonCode.DisplayMember = cstReasonCode Then              				'WO#3282
                            'WO#3282 cboReasonCode.Width = 80
                            cboReasonCode.Width = cstIntReasonCodeWidth                					'WO#3282
                            cboReasonCode.Font = New Font("Arial", 18, System.Drawing.FontStyle.Regular)
                            lblReasonCodeDesc.Visible = True
                            'lblReasonCodeDesc.Text = tblDTReasonCode.Rows(0)("Description")
                        End If                                                          				'WO#3282
                        'WO#3282 ADD Start
                        gblnCommentRequired = tblDTReasonCode.Rows(0)("CommentRequired")
                        If gblnCommentRequired = True Then
                            If gstrComment = "" Then
                                frmComment.ShowDialog()
                                If gstrComment = "" Then
                                    gstrErrMsg = "Comment is mandatory for this reason code. "
                                    If cboReasonCode.DisplayMember = cstReasonCode Then
                                        lblReasonCodeDesc.Text = ""
                                        cboReasonCode.Text = ""
                                    Else
                                        cboReasonCode.SelectedValue = 0
                                        lblReasonCodeDesc.Text = ""
                                        cboReasonCode.Text = ""
                                    End If
                                    cboReasonCode.Focus()
                                End If
                            End If
                        Else
                            gstrComment = ""
                        End If
                        'WO#3282 ADD Stop
                    End If
                End If

                If Not IsNothing(gstrErrMsg) Then
                    If gblnCommentRequired = True And gstrComment = "" Then
                        lblReasonCodeDesc.Visible = True
                    Else
                        lblReasonCodeDesc.Visible = False
                    End If
                End If

            End If
        Catch ex As SqlClient.SqlException
            ChkErr(ex)
        Catch ex As Exception
            Throw New Exception("Error in cboReasonCode_TextChanged" & Environment.NewLine & ex.Message)
        End Try
    End Sub

    Private Sub cboReasonCode_Validating(ByVal sender As Object, ByVal e As System.ComponentModel.CancelEventArgs) Handles cboReasonCode.Validating
        If (ActiveControl.Name = "btnPrvScn") Then
            Me.Close()
        Else
            If Not IsNothing(gstrErrMsg) Then
                MessageBox.Show(gstrErrMsg, "Invalid information")
                e.Cancel = True
            End If
        End If
    End Sub

    Private Sub btnDTInquiry_Click(ByVal sender As Object, ByVal e As System.EventArgs) Handles btnDTInquiry.Click
        Try
            frmViewDTLog.ShowDialog()
        Catch ex As Exception
            Throw New Exception("Error in btnDtInquiry_Click" & Environment.NewLine & ex.Message)
        End Try
    End Sub

    Private Sub txtShift_TextChanged(ByVal sender As Object, ByVal e As System.EventArgs) Handles txtShift.TextChanged
        Dim daShift As New dsShiftTableAdapters.CPPsp_ShiftIOTableAdapter
        Dim dtShift As New dsShift.CPPsp_ShiftIODataTable
        Try
            gstrErrMsg = Nothing
            If txtShift.Text <> "" Then
                'WO#2645    If txtShift.Text < "1" Or txtShift.Text > 3 Then
                'WO#2645 Add Start
                daShift.Fill(dtShift, "AllShifts", gstrFacility, gstrMachineType, Now(), Nothing, 1)
                If dtShift.Rows.Count = 0 Then
                    gstrErrMsg = "The pre-defined shift information is missing, please contact supervisor."
                    MessageBox.Show(gstrErrMsg, "Missing Information", MessageBoxButtons.OK, MessageBoxIcon.Error)
                    txtShift.Focus()
                ElseIf CType(txtShift.Text, Integer) < 1 Or CType(txtShift.Text, Integer) > dtShift.Rows.Count Then
                    gstrErrMsg = "Please entered a valid shift no. from 1 to " & CType(dtShift.Rows.Count, String) & "."
                    'WO#2645 Add Stop
                    'WO#2645    gstrErrMsg = "Shift only allows 1, 2 or 3."
                    MessageBox.Show(gstrErrMsg, "Invalid information")
                    txtShift.Focus()
                End If
            End If
        Catch ex As SqlClient.SqlException
            ChkErr(ex)
        Catch ex As Exception
            Throw New Exception("Error in txtshift_TextChanged" & Environment.NewLine & ex.Message)
        End Try
    End Sub

    Private Sub txtShift_Validating(ByVal sender As Object, ByVal e As System.ComponentModel.CancelEventArgs) Handles txtShift.Validating
        If (ActiveControl.Name = "btnPrvScn") Then
            Me.Close()
        Else
            If Not IsNothing(gstrErrMsg) Then
                MessageBox.Show(gstrErrMsg, "Invalid information")
                e.Cancel = True
            End If
        End If
    End Sub

    Private Sub RefreshDTLog(ByVal dteBeginTime As DateTime)

        Try
            If gblnConnectUp = False Then
                SharedFunctions.AddMessageLineToForm(Me, gcstSvrCnnFailure)
            Else
                SharedFunctions.RmvMessageLineFromForm(Me)
            End If
            'WO#648 gtaDownTimeLog.FillByStartTime(Me.DsDownTimeLog.tblDownTimeLog, gstrFacility, gstrMachineType, gstrMachineID, dteBeginTime, txtOperator.Text)
            gtaDownTimeLog.FillByStartTime(DsDownTimeLog.CPPsp_DownTimeLog_Sel, "FilterByStartTime", gstrFacility, gstrMachineType, dteBeginTime, gstrMachineID, txtOperator.Text, False)
            If DsDownTimeLog.CPPsp_DownTimeLog_Sel.Rows.Count > 0 Then
                dgvDTLog.Visible = True
            Else
                dgvDTLog.Visible = False
            End If
        Catch ex As SqlClient.SqlException
            If ex.ErrorCode = -2146232060 And (ex.Number = 64 Or ex.Number = 1231 Or ex.Number = 11001) Then
                If String.IsNullOrEmpty(gstrLocalCnnStr) Then
                    Throw ex
                Else
                    If gblnConnectUp = True Then
                        gtaDownTimeLog.Connection.ConnectionString = gstrLocalCnnStr
                        SharedFunctions.AddMessageLineToForm(Me, gcstSvrCnnFailure)
                        gblnConnectUp = False

                        gtaDownTimeLog.FillByStartTime(DsDownTimeLog.CPPsp_DownTimeLog_Sel, "FilterByStartTime", gstrFacility, gstrMachineType, dteBeginTime, gstrMachineID, txtOperator.Text, False)   'WO#648
                    Else
                        Throw ex
                    End If
                End If
            Else
                Throw ex
                'Throw New Exception("Error inRefreshDTLog" & Environment.NewLine & ex.Message)
            End If
        Catch ex As System.Exception
            Throw ex
        End Try
    End Sub

    Public ReadOnly Property StartTime() As DateTime

        Get
            DateTime.TryParse(txtBeginDate.Text.Insert(4, "/").Insert(7, "/") & " " & txtBeginTime.Text.Insert(2, ":") & ":00", StartTime)
        End Get

    End Property

    Private Sub ChkErr(ByVal ex As SqlClient.SqlException)
        'If the computer does not has local data base for the down time and you try to throw the SQL exception, an unhandle
        'execption is treated. That is why this subroutine for.
        Static blnError As Boolean = False
        If Not String.IsNullOrEmpty(gstrLocalCnnStr) Then
            Throw ex
        Else
            If ex.ErrorCode = -2146232060 AndAlso (ex.Number = 64 Or ex.Number = 1231 Or ex.Number = 11001 Or ex.Number = 10054) Then
                If blnError = False Then
                    MessageBox.Show("Data base server connection failed. Please contact supervisor and try again later.")
                    blnError = True
                End If
            Else
                MessageBox.Show(ex.Message & vbCrLf & ex.StackTrace, "** Unexpected Application Error - Contact Supervisor")
            End If
            Me.Close()
        End If
    End Sub

    Private Sub btnHybernate_Click(sender As Object, e As System.EventArgs) Handles btnHybernate.Click
        Me.SendToBack()
    End Sub

    Private Sub dgvDTLog_CellFormatting(sender As Object, e As DataGridViewCellFormattingEventArgs) Handles dgvDTLog.CellFormatting
        If e.ColumnIndex = dgvDTLog.Columns("Description").Index _
        AndAlso (e.Value IsNot Nothing) Then

            With dgvDTLog.Rows(e.RowIndex).Cells(e.ColumnIndex)
                If Not IsDBNull(dgvDTLog.Rows(e.RowIndex).Cells(e.ColumnIndex + 1).Value) Then
                    .ToolTipText = "Comment: " & Me.dgvDTLog.Rows(e.RowIndex).Cells(e.ColumnIndex + 1).Value
                End If
            End With

        End If

    End Sub
End Class