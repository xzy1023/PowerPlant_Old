Public Class frmDownTime
    Public gtblDTReasonType As New dsDTReasonType.tblDTReasonTypeDataTable
    Public gtblDTReasonCode As New dsDTReasonCode.tblDTReasonCodeDataTable
    Public gtblPlantStaff As New dsPlantStaff.CPPsp_PlantStaffingIODataTable
    Public gintSize As Short
    Public gblnDropDownIsClicked As Boolean
    Public gfntdefaultFont As New Font("Arial", 18, System.Drawing.FontStyle.Regular)
    Dim gstrReasonType As String
    Dim strComment As String = Nothing							'WO#3282
    Const cstIntReasonCodeWidth As Short = 105                  'WO#3282

    Private Sub frmDownTime_FormClosing(ByVal sender As Object, ByVal e As System.Windows.Forms.FormClosingEventArgs) Handles Me.FormClosing
        If Not String.IsNullOrEmpty(gstrLocalCnnStr) Then
            SharedFunctions.UpdateSessionControlDownTime(False)
        End If
    End Sub

    Private Sub frmDownTime_Load(ByVal sender As Object, ByVal e As System.EventArgs) Handles Me.Load
        Dim dtEQ As dsEquipment.dtEquipmentDataTable
        Try
            Windows.Forms.Cursor.Current = Cursors.WaitCursor
            UcHeading1.ScreenTitle = "Down Time"
            SharedFunctions.ClearInputFields(Me)
            lblOperator.Visible = False
            lblTechnician.Visible = False
            lblComment.Visible = False
            RTBComment.Visible = False
            lblReasonCodeDesc.Visible = False
            txtTechnician.Text = ""
            txtBeginDate.Text = Format(Now, "yyyyMMdd")
            txtBeginTime.Text = Format(Now, "HHmm")
            If Not IsDBNull(gintShopOrder) AndAlso gintShopOrder > 0 Then
                lblShopOrderNo.Text = gintShopOrder
                If gstrMachineType = "P" Then
                    lblShopOrder.Text = "Shop Order:"
                End If
                lblShopOrder.Visible = True
                lblShopOrderNo.Visible = True
            Else
                lblShopOrderNo.Text = 0
                lblShopOrder.Visible = False
                lblShopOrderNo.Visible = False
            End If
            If Not IsDBNull(gintShift) Then
                txtShift.Text = gintShift
            End If
            If Not IsDBNull(gstrOperator) Then
                txtOperator.Text = gstrOperator
            End If

            'WO#648 ADD Start
            dtEQ = SharedFunctions.GetSharedEquiptmentList(gstrFacility, gstrMachineID, gstrMachineType, gstrMachineSubType, "ActiveSharedGroup")
            With cboMachine
                .DataSource = dtEQ
                .DisplayMember = "EquipmentID"
                .ValueMember = "EquipmentID"
                .SelectedValue = gstrMachineID
            End With

            'WO#648 ADD Stop

            gtaDTReasonType.Fill(gtblDTReasonType, gstrFacility, gstrMachineType, gstrMachineSubType)
            With cboReasonType
                .DataSource = gtblDTReasonType
                .DisplayMember = "Description"
                .ValueMember = "ReasonType"
                .SelectedValue = 0
            End With
            If gblnConnectUp = True Then
                SharedFunctions.RmvMessageLineFromForm(Me)
            Else
                SharedFunctions.AddMessageLineToForm(Me, gcstSvrCnnFailure)
            End If

            If Not String.IsNullOrEmpty(gstrLocalCnnStr) Then
                SharedFunctions.UpdateSessionControlDownTime(True)
            End If

            dgvDTLog.Visible = False

        Catch ex As SqlClient.SqlException
            ChkErr(ex)
        Catch ex As Exception
            Throw New Exception("Error in frmDownTime_Load" & vbCrLf & ex.Message)
        Finally
            Windows.Forms.Cursor.Current = Cursors.Default
        End Try
    End Sub

    Private Sub popupNumKeyPad(ByVal sender As Object, ByVal e As System.Windows.Forms.MouseEventArgs) Handles txtOperator.MouseDown, _
                       txtBeginDate.MouseDown, txtBeginTime.MouseDown, txtTechnician.MouseDown, txtDuration.MouseDown, txtShift.MouseDown
        Dim dgrKeyPad As DialogResult
        Try
            If TypeOf sender Is TextBox Then
                dgrKeyPad = SharedFunctions.PopNumKeyPad(Me, sender)
                If dgrKeyPad = Windows.Forms.DialogResult.OK Then
                    If Not IsNothing(gstrNumPadValue) AndAlso gstrNumPadValue <> "" Then
                        sender.text = Microsoft.VisualBasic.Left(gstrNumPadValue, sender.maxLength)
                    Else
                        sender.text = ""
                    End If
                End If
            End If
        Catch ex As Exception
            MessageBox.Show(ex.Message & vbCrLf & ex.StackTrace, "** Unexpected Application Error - Contact Supervisor", MessageBoxButtons.OK, MessageBoxIcon.Error)
        End Try
    End Sub

    Private Sub cboReasonCode_DropDownClosed(ByVal sender As Object, ByVal e As System.EventArgs) Handles cboReasonCode.DropDownClosed
        cboReasonCode.Font = gfntdefaultFont
    End Sub

    Private Sub popupAlphaNumKB(ByVal sender As Object, ByVal e As System.Windows.Forms.MouseEventArgs) Handles cboReasonCode.MouseDown
        Dim dgrKeyPad As DialogResult
        Try
            'WO#3282    If TypeOf sender Is TextBox Or (sender.name = "cboReasonCode" AndAlso cboReasonType.SelectedValue = 0 And gblnDropDownIsClicked = False) Then
            If cboReasonType.SelectedValue = 0 And gblnDropDownIsClicked = False Then   'WO#3282  
                gblnCancelComment = False             'WO#3282
                dgrKeyPad = SharedFunctions.PopAlphaNumKB(Me, sender)
                If dgrKeyPad = Windows.Forms.DialogResult.OK Then
                    If Not IsNothing(gstrNumPadValue) AndAlso gstrNumPadValue <> "" Then
                        sender.text = Microsoft.VisualBasic.Left(gstrNumPadValue, sender.maxLength)
                    Else
                        If Not IsNothing(cboReasonCode.SelectedValue) Then          'WO#3282
                            cboReasonCode.SelectedValue = 0							'WO#3282
                        Else														'WO#3282
                            sender.text = ""
                        End If														'WO#3282

                    End If
                End If
            End If
            If TypeOf sender Is ComboBox Then
                gblnDropDownIsClicked = False
            End If
        Catch ex As Exception
            MessageBox.Show(ex.Message & vbCrLf & ex.StackTrace, "** Unexpected Application Error - Contact Supervisor", MessageBoxButtons.OK, MessageBoxIcon.Error)
        End Try
    End Sub
