    Private Sub txtBeginDate_TextChanged(ByVal sender As Object, ByVal e As System.EventArgs) Handles txtBeginDate.TextChanged
        Try
            gstrErrMsg = Nothing
            If txtBeginDate.Text <> "" Then
                If Not IsDate(txtBeginDate.Text.Insert(4, "/").Insert(7, "/")) Then
                    gstrErrMsg = "Please Enter a valid date in Year/Month/Day format."
                    MessageBox.Show(gstrErrMsg, "Invalid Information")
                End If
            End If
        Catch ex As SqlClient.SqlException
            ChkErr(ex)
        Catch ex As Exception
            Throw New Exception("Error in txtBeginDate_TextChanged" & vbCrLf & ex.Message)
        End Try
    End Sub

    Private Sub txtBeginDate_Validating(ByVal sender As Object, ByVal e As System.ComponentModel.CancelEventArgs) Handles txtBeginDate.Validating
        If (ActiveControl.Name = "btnPrvScn") Then
            Me.Close()
        Else
            If Not IsNothing(gstrErrMsg) Then
                MessageBox.Show(gstrErrMsg, "Invalid information")
                e.Cancel = True
            End If
        End If
    End Sub

    Private Sub txtBeginTime_TextChanged(ByVal sender As Object, ByVal e As System.EventArgs) Handles txtBeginTime.TextChanged
        Try
            gstrErrMsg = Nothing
            If txtBeginTime.Text <> "" Then
                If txtBeginTime.Text.Length <> 4 Then
                    gstrErrMsg = "Time must be 4 digits long in 24Hour/Minute format."
                    MessageBox.Show(gstrErrMsg, "Invalid Information")
                    txtBeginTime.Focus()
                ElseIf txtBeginTime.Text.Substring(0, 2) > 23 Then
                    gstrErrMsg = "Hour must be between 0 to 23."
                    MessageBox.Show(gstrErrMsg, "Invalid Information")
                    txtBeginTime.Focus()
                ElseIf txtBeginTime.Text.Substring(2, 2) > 59 Then
                    gstrErrMsg = "Minute must be between 0 to 59."
                    MessageBox.Show(gstrErrMsg, "Invalid Information")
                    txtBeginTime.Focus()
                Else
                    RefreshDTLog(StartTime)
                End If
            End If
        Catch ex As SqlClient.SqlException
            ChkErr(ex)
        Catch ex As Exception
            Throw New Exception("Error in txtBeginTime_TextChanged" & vbCrLf & ex.Message)
        End Try
    End Sub

    Private Sub txtBeginTime_Validating(ByVal sender As Object, ByVal e As System.ComponentModel.CancelEventArgs) Handles txtBeginTime.Validating
        Try

            If (ActiveControl.Name = "btnPrvScn") Then
                Me.Close()
            Else
                If Not IsNothing(gstrErrMsg) Then
                    MessageBox.Show(gstrErrMsg, "Invalid information")
                    e.Cancel = True
                End If
            End If

        Catch ex As Exception
            Throw New Exception("Error in txtBeginTime_Validating" & vbCrLf & ex.Message)
        End Try
    End Sub

