    Private Sub btnAccept_Click(ByVal sender As Object, ByVal e As System.EventArgs) Handles btnAccept.Click
        Try
            Dim dteDTBegin As DateTime
            Dim dteDTEnd As DateTime
            Dim strReasonType = "", intReasonCode As Int16
            Dim dteGivenDateTime As DateTime
            Dim dteShiftProductionDate As DateTime
            Dim tblDTReasonCode As New dsDTReasonCode.tblDTReasonCodeDataTable
            Dim intShift As Int16

            If Me.txtShift.Text = "" Then
                MessageBox.Show("Please enter a Shift No.", "Missing information")
                Me.txtShift.Focus()
            ElseIf Me.txtOperator.Text = "" Then
                MessageBox.Show("Please enter a Operator ID.", "Missing information")
                Me.txtOperator.Focus()
                'ElseIf Me.txtTechnician.Text = "" Then
                '    MessageBox.Show("Please enter a Technician ID.", "Missing information")
                '    Me.txtTechnician.Focus()
            ElseIf Me.txtBeginDate.Text = "" Then
                MessageBox.Show("Please enter the Date Begin.", "Missing information")
                Me.txtBeginDate.Focus()
            ElseIf Me.txtBeginTime.Text = "" Then
                MessageBox.Show("Please enter the Time Begin.", "Missing information")
                Me.txtBeginTime.Focus()
            ElseIf Me.txtDuration.Text = "" Then
                MessageBox.Show("Please enter Down Time Duration.", "Missing information")
                Me.txtDuration.Focus()
            ElseIf Me.cboReasonCode.Text = "" Then
                MessageBox.Show("Please enter Reason Code.", "Missing information")
                Me.cboReasonCode.Focus()
            ElseIf gblnCommentRequired = True And gstrComment = "" Then                     'WO#3282
                MessageBox.Show("Comment is mandatory for this reason code.")               'WO#3282
                cboReasonCode.Focus()                                                       'WO#3282
            Else
                dteDTBegin = CType(txtBeginDate.Text.Insert(4, "/").Insert(7, "/") & " " & txtBeginTime.Text.Insert(2, ":") & ":00", DateTime)
                If dteDTBegin > Now() Then
                    MessageBox.Show("The begin Date/time can not be in future.", "Invalid information")
                    Me.cboReasonCode.Focus()
                Else
                    dteDTEnd = DateAdd(DateInterval.Minute, CType(txtDuration.Text, Integer), dteDTBegin)
                    If cboReasonCode.SelectedValue Is Nothing Then
                        intReasonCode = CType(cboReasonCode.Text, Int16)
                    Else
                        intReasonCode = CType(cboReasonCode.SelectedValue, Int16)
                    End If
                    strReasonType = cboReasonType.SelectedValue
                    Dim sb As New System.Text.StringBuilder
                    With sb
                        Dim strGivenDateTime As String = txtBeginDate.Text & txtBeginTime.Text
                        .Append(strGivenDateTime)
                        .Insert(4, "-", 1)  'insert "-" after Year
                        .Insert(7, "-", 1) 'insert "-" after Month
                        .Insert(10, " ", 1) 'insert a blank after Day
                        .Insert(13, ":", 1) 'insert a ":" after Hour
                        .Insert(16, ":00", 1) 'insert a ":00" after minute
                        dteGivenDateTime = CType(.ToString, DateTime)
                    End With

                    'If selected Reason type is 0 (i.e. ALL), use the reason type from the entered reason code.
                    If strReasonType = 0 Then
                        gtaDTReasonCode.FillByReasonCode(tblDTReasonCode, gstrMachineType, gstrMachineSubType, intReasonCode, gstrFacility)
                        If tblDTReasonCode.Rows.Count > 0 Then
                            strReasonType = tblDTReasonCode.Rows(0).Item("ReasonType")
                        End If
                    End If

                    'If the down time is from packaging line, use the ShiftProductionDate and shift from the Session Control table 
                    Dim drSC As dsSessionControl.CPPsp_SessionControlIORow = Nothing
                    Dim drSCH As dsSessionControlHst.CPPsp_SessionControlHstIORow = Nothing
                    Dim blnGetShiftFromInput As Boolean = True

                    If gstrMachineType = "P" AndAlso gintShopOrder > 0 AndAlso Not String.IsNullOrEmpty(gstrLocalCnnStr) Then
                        drSC = SharedFunctions.GetSessionControl()
                        If Not drSC Is Nothing Then
                            If dteGivenDateTime >= drSC.StartTime Then
                                blnGetShiftFromInput = False
                                dteShiftProductionDate = drSC.ShiftProductionDate
                                intShift = drSC.OverrideShiftNo
                            Else
                                drSCH = SharedFunctions.GetSessionControlHst(gstrFacility, gstrMachineID, gintShopOrder, dteGivenDateTime)
                                If Not drSCH Is Nothing Then
                                    blnGetShiftFromInput = False
                                    dteShiftProductionDate = drSCH.ShiftProductionDate
                                    intShift = drSCH.OverrideShiftNo
                                End If
                            End If
                        End If
                    End If

                    'If blnGetShiftFromInput = False Then
                    '    dteShiftProductionDate = drSC.ShiftProductionDate
                    '    intShift = drSC.OverrideShiftNo
                    'Else
                    If blnGetShiftFromInput = True Then
                        dteShiftProductionDate = SharedFunctions.GetProductionDateByShift(gstrFacility, CType(txtShift.Text, Short), dteGivenDateTime, gstrMachineID, gstrMachineType)
                        intShift = CType(txtShift.Text, Int16)
                    End If

                    Try
                        'WO648 gtaDownTimeLog.Insert(False, gstrFacility, CType(lblShopOrderNo.Text, Integer), gstrMachineType, gstrMachineSubType, gstrMachineID, txtOperator.Text, _
                        'WO648 txtTechnician.Text, dteDTBegin, dteDTEnd, intShift, strReasonType, _
                        'WO648 intReasonCode, RTBComment.Text, txtOperator.Text, Now, txtOperator.Text, Now, dteShiftProductionDate, gstrEventID)
                        'WO648 ADD Start
                        gtaDownTimeLog.Insert(False, gstrFacility, CType(lblShopOrderNo.Text, Integer), gstrMachineType, gstrMachineSubType, cboMachine.SelectedValue, _
                                              txtOperator.Text, txtTechnician.Text, dteDTBegin, dteDTEnd, intShift, strReasonType, _
                                              intReasonCode, strComment, txtOperator.Text, Now, txtOperator.Text, Now, dteShiftProductionDate, gstrEventID)
                        'WO#3282              intReasonCode, RTBComment.Text, txtOperator.Text, Now, txtOperator.Text, Now, dteShiftProductionDate, gstrEventID)
                        'WO648 ADD Stop
                    Catch ex As SqlClient.SqlException
                        If ex.ErrorCode = -2146232060 AndAlso (ex.Number = 64 Or ex.Number = 1231 Or ex.Number = 11001 Or ex.Number = 10054) AndAlso Not String.IsNullOrEmpty(gstrLocalCnnStr) Then
                            gtaDownTimeLog.Connection.ConnectionString = gstrLocalCnnStr
                            'WO648 DEL Start
                            'gtaDownTimeLog.Insert(False, gstrFacility, CType(lblShopOrderNo.Text, Integer), gstrMachineType, gstrMachineSubType, gstrMachineID, txtOperator.Text, _
                            '                  txtTechnician.Text, dteDTBegin, dteDTEnd, txtShift.Text, strReasonType, _
                            '                  intReasonCode, RTBComment.Text, txtOperator.Text, Now, txtOperator.Text, Now, dteShiftProductionDate, gstrEventID)
                            'WO648 DEL Start
                            'WO648 ADD Start
                            gtaDownTimeLog.Insert(False, gstrFacility, CType(lblShopOrderNo.Text, Integer), gstrMachineType, gstrMachineSubType, cboMachine.SelectedValue, _
                                                  txtOperator.Text, txtTechnician.Text, dteDTBegin, dteDTEnd, intShift, strReasonType, _
                                                 intReasonCode, strComment, txtOperator.Text, Now, txtOperator.Text, Now, dteShiftProductionDate, gstrEventID)
                            'WO#3282             intReasonCode, RTBComment.Text, txtOperator.Text, Now, txtOperator.Text, Now, dteShiftProductionDate, gstrEventID)
                            'WO648 ADD Stop
                            gblnConnectUp = False
                            SharedFunctions.AddMessageLineToForm(Me, gcstSvrCnnFailure)
                        Else
                            Throw ex
                        End If
                    End Try
                    lblComment.Visible = False
                    RTBComment.Visible = False
                    RTBComment.Text = ""
                    gstrComment = "" 					                'WO#3282 
                    lblReasonCodeDesc.Visible = False
                    txtTechnician.Text = ""
                    lblTechnician.Visible = False
                    'txtBeginDate.Text = Format(Now, "yyyyMMdd")
                    'txtBeginTime.Text = Format(Now, "HHmm")
                    txtDuration.Text = ""
                    'WO#3282 cboReasonCode.Text = ""
                    cboReasonCode.SelectedValue = 0                     'WO#3282 
                    lblReasonCodeDesc.Visible = False
                    RefreshDTLog(dteDTBegin)
                End If
            End If
        Catch ex As SqlClient.SqlException
            ChkErr(ex)
        Catch ex As Exception
            Throw New Exception("Error in btnAccept_Click" & vbCrLf & ex.Message)
        End Try
    End Sub

    Private Sub btnEndNow_Click(ByVal sender As Object, ByVal e As System.EventArgs) Handles btnEndNow.Click
        Try
            If Trim(txtBeginDate.Text) = "" Then
                MessageBox.Show("Please enter the Date Begin.", "Missing information")
                Me.txtBeginDate.Focus()
            ElseIf Me.txtBeginTime.Text = "" Then
                MessageBox.Show("Please enter the Time Begin.", "Missing information")
                Me.txtBeginTime.Focus()
            Else
                txtDuration.Text = DateDiff(DateInterval.Minute, CType(txtBeginDate.Text.Insert(4, "/").Insert(7, "/") & " " & txtBeginTime.Text.Insert(2, ":") & ":00", DateTime), _
                                                Now)
            End If

        Catch ex As Exception
            Throw New Exception("Error in btnEndNow_Click" & Environment.NewLine & ex.Message)
        End Try
    End Sub

    Private Sub txtDuration_TextChanged(ByVal sender As Object, ByVal e As System.EventArgs) Handles txtDuration.TextChanged
        Try
            gstrErrMsg = Nothing
            If RTrim(txtDuration.Text) <> "" Then
                If txtDuration.Text <= 0 Then
                    gstrErrMsg = "The Duration must be greater than zero."
                    MessageBox.Show(gstrErrMsg, "Invalid Information")
                    txtDuration.Focus()
                End If
            End If
        Catch ex As Exception
            Throw New Exception("Error in txtDuration_TextChanged" & Environment.NewLine & ex.Message)
        End Try
    End Sub

