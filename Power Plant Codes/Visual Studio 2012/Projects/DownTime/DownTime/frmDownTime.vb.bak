        End Try
    End Sub

    Private Sub txtOperator_TextChanged(ByVal sender As Object, ByVal e As System.EventArgs) Handles txtOperator.TextChanged
        Try
            gstrErrMsg = Nothing
            If txtOperator.Text <> "" Then
                lblOperator.Visible = False
                gtaPlantStaff.Fill(gtblPlantStaff, "SelectAllFields", txtOperator.Text, gstrMachineType)
                If gtblPlantStaff.Rows.Count > 0 Then
                    lblOperator.Visible = True
                    lblOperator.Text = gtblPlantStaff.Rows(0)("FullName")

                Else
                    gstrErrMsg = "Invalid Opeartor ID, Please entry again."
                    MessageBox.Show(gstrErrMsg, "Invalid information")
                    sender.focus()
                End If
            End If
        Catch ex As SqlClient.SqlException
            ChkErr(ex)
        Catch ex As Exception
            Throw New Exception("Error in txtOperator_TextChanged" & vbCrLf & ex.Message)
        End Try
    End Sub

