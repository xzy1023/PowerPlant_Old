    <DataSet Name="dsMaxShiftNo">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@vchFacility">
            <Value>=Parameters!vchFacility.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        MAX(Shift) AS MaxShiftNo
FROM            tblShift
WHERE        (Facility = @vchFacility)</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="MaxShiftNo">
          <DataField>MaxShiftNo</DataField>
          <rd:TypeName>System.Byte</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
