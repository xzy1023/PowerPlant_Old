                      <CellContents>
                        <Textbox Name="ActualChangeover">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=Fields!ActualChangeOverTime.Value</Value>
                                  <Style>
                                    <Color>Blue</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Right</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <ActionInfo>
                            <Actions>
                              <Action>
                                <Drillthrough>
                                  <ReportName>Down Time Details</ReportName>
                                  <Parameters>
                                    <Parameter Name="vchAction">
                                      <Value>="ByPrdDateShiftRange_Line_Opt_ActivityID"</Value>
                                    </Parameter>
                                    <Parameter Name="chrFacility">
                                      <Value>=Parameters!chrFacility.Value</Value>
                                    </Parameter>
                                    <Parameter Name="vchPackagingLine">
                                      <Value>=Fields!ActualLineID.Value</Value>
                                    </Parameter>
                                    <Parameter Name="vchOperator">
                                      <Value>=Fields!OperatorID.Value</Value>
                                    </Parameter>
                                    <Parameter Name="vchActivityID">
                                      <Value>=Fields!ShopOrder.Value</Value>
                                    </Parameter>
                                    <Parameter Name="dteFromProdDate">
                                      <Value>=Parameters!dteFromDate.Value</Value>
                                    </Parameter>
                                    <Parameter Name="intFromShift">
                                      <Value>1</Value>
                                    </Parameter>
                                    <Parameter Name="dteToProdDate">
                                      <Value>=DATEADD("D",10,Parameters!dteToDate.Value)</Value>
                                    </Parameter>
                                    <Parameter Name="intToShift">
                                      <Value>3</Value>
                                    </Parameter>
                                    <Parameter Name="intShiftNoFilter">
                                      <Value>0</Value>
                                    </Parameter>
                                  </Parameters>
                                </Drillthrough>
                              </Action>
                            </Actions>
                          </ActionInfo>
                          <ZIndex>2</ZIndex>
                          <Style>
                            <BackgroundColor>=iif(RowNumber(Nothing) Mod 2, "WhiteSmoke", "White")</BackgroundColor>
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
                        </Textbox>
                      </CellContents>
                    </TablixCell>
