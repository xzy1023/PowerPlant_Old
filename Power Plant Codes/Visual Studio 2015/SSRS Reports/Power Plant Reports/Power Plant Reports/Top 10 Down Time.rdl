    <DataSet Name="dsLineOrOperator">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@vchFacility">
            <Value>=Parameters!vchFacility.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@vchReportType">
            <Value>=Parameters!vchReportType.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>Select EquipmentID as Value, Description 
From tblEquipment 
Where facility = @vchFacility AND [Type] = 'P' AND Description NOT IN ('Spare' ,'PALLET STATION') AND  @vchReportType = 'ByLine'
UNION
Select StaffId as Value, FirstName  + ' ' + LastName as Description from tblplantstaff 
Where (@vchReportType = 'ByOperator' OR @vchReportType = 'ByUT') and facility = @vchFacility and (Workgroup = 'P' or WorkGroup = 'ALL') 
UNION
Select Cast(WorkCenter as varchar(10)) as Value, Description From tblWorkCenter 
Where facility = @vchFacility and @vchReportType='ByWorkCenter'  AND Description NOT like '%PALLET%'
UNION
Select NULL as Value,'*ALL'  as Description
Order by Description</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Value">
          <DataField>Value</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
