    <Report Include="Pallet Station Status - Not Use.rdl" />
    <Report Include="QA Main Menu.rdl" />
    <Report Include="Reconcile Cases Produced By Date .rdl" />
    <Report Include="Reconcile Cases Produced.rdl" />
    <Report Include="Rework.rdl" />
    <Report Include="Scrapped Components by Shop Order.rdl" />
    <Report Include="Scrapped Components Inventory Adjustment.rdl" />
