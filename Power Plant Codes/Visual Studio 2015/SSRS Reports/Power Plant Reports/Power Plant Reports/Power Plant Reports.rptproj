<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="Current" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <FullPath>Debug</FullPath>
    <OutputPath>bin\Debug</OutputPath>
    <ErrorLevel>2</ErrorLevel>
    <OverwriteDatasets>False</OverwriteDatasets>
    <OverwriteDataSources>False</OverwriteDataSources>
    <TargetServerVersion>SSRS2016</TargetServerVersion>
    <Platform>Win32</Platform>
    <TargetReportFolder>Power Plant Reports UA</TargetReportFolder>
    <TargetDatasetFolder>Power Plant Data Sets UA</TargetDatasetFolder>
    <TargetDatasourceFolder>Power Plant Data Sources UA</TargetDatasourceFolder>
    <TargetReportPartFolder>Report Parts</TargetReportPartFolder>
    <TargetServerURL>http://mpajpp01/reportserver</TargetServerURL>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'DebugLocal' ">
    <FullPath>DebugLocal</FullPath>
    <OutputPath>bin\DebugLocal</OutputPath>
    <ErrorLevel>2</ErrorLevel>
    <OverwriteDatasets>False</OverwriteDatasets>
    <OverwriteDataSources>False</OverwriteDataSources>
    <TargetServerVersion>SSRS2016</TargetServerVersion>
    <Platform>Win32</Platform>
    <TargetReportFolder>Power Plant Reports</TargetReportFolder>
    <TargetDatasetFolder>Datasets</TargetDatasetFolder>
    <TargetDatasourceFolder>Data Sources</TargetDatasourceFolder>
    <TargetReportPartFolder>Report Parts</TargetReportPartFolder>
    <TargetServerURL>http://localhost/reportserver</TargetServerURL>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <FullPath>Release</FullPath>
    <OutputPath>bin\Release</OutputPath>
    <ErrorLevel>2</ErrorLevel>
    <OverwriteDatasets>False</OverwriteDatasets>
    <OverwriteDataSources>False</OverwriteDataSources>
    <TargetServerVersion>SSRS2016</TargetServerVersion>
    <Platform>Win32</Platform>
    <TargetReportFolder>Power Plant Reports</TargetReportFolder>
    <TargetDatasetFolder>Power Plant Data Sets</TargetDatasetFolder>
    <TargetDatasourceFolder>Power Plant Data Sources</TargetDatasourceFolder>
    <TargetReportPartFolder>Report Parts</TargetReportPartFolder>
    <TargetServerURL>http://mpsppp02/reportserver</TargetServerURL>
  </PropertyGroup>
  <PropertyGroup>
    <State>$base64$</State>
    <DataSources>@(DataSource)</DataSources>
    <DataSets>@(DataSet)</DataSets>
    <Reports>@(Report)</Reports>
  </PropertyGroup>
  <ItemGroup>
    <DataSet Include="dsDftFacility.rsd" />
    <DataSet Include="dsFacility.rsd" />
    <DataSet Include="dsMachine.rsd" />
    <DataSet Include="dsWorkCenter.rsd" />
  </ItemGroup>
  <ItemGroup>
    <DataSource Include="DynamicsAX.rds" />
    <DataSource Include="PowerPlant.rds" />
    <DataSource Include="PowerPlant_UA.rds" />
  </ItemGroup>
  <ItemGroup>
    <Report Include="Actual Machine Efficiency Chart V0.0.rdl" />
    <Report Include="Actual Machine Efficiency Chart with Trend line V0.0.rdl" />
    <Report Include="Actual Machine Efficiency Chart with Trend line.rdl" />
    <Report Include="Actual Machine Efficiency Chart.rdl" />
    <Report Include="AX Interface Error Summary.rdl" />
    <Report Include="Copy (2) of Work Center Efficiency Report New.rdl" />
    <Report Include="Copy of Item Efficiency Report New.rdl" />
    <Report Include="Copy of Labor and Machine Efficiency New.rdl" />
    <Report Include="Copy of Labor Efficiency New.rdl" />
    <Report Include="Copy of Line Efficiency New.rdl" />
    <Report Include="Copy of QA Main Menu.rdl" />
    <Report Include="Copy of Work Center Efficiency Report New.rdl" />
    <Report Include="Copy of Work Center Efficiency Summary Report.rdl" />
    <Report Include="Daily Production.rdl" />
