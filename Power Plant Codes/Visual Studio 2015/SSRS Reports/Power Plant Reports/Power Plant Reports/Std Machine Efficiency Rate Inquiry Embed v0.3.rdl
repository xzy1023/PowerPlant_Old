    </DataSet>
    <DataSet Name="dsMachine">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@chrFacility">
            <Value>=Parameters!vchFacility.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@intWorkCenter">
            <Value>=Parameters!intWorkCenter.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@chrType">
            <Value>="P"</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        NULL AS EquipmentID, '*ALL' AS Description
UNION
SELECT        EquipmentID, Description
FROM            tblEquipment
WHERE        (facility = @chrFacility) AND (WorkCenter = ISNULL(@intWorkCenter, WorkCenter)) AND (Type = @chrType) AND (Active = 1)
ORDER BY Description</CommandText>
      </Query>
      <Fields>
        <Field Name="EquipmentID">
          <DataField>EquipmentID</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
