          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
      <Filters>
        <Filter>
          <FilterExpression>=IIF(Parameters!bitCurrentRate.Value = false,Fields!EffectiveTime.Value, Parameters!dteStartFrom.Value)</FilterExpression>
          <Operator>GreaterThanOrEqual</Operator>
          <FilterValues>
            <FilterValue>=Parameters!dteStartFrom.Value</FilterValue>
          </FilterValues>
        </Filter>
      </Filters>
