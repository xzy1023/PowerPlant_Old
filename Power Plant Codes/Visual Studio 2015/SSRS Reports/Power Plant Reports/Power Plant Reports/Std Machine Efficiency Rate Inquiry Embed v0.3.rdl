    <DataSet Name="dsWorkCenter">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@vchAction">
            <Value>="AllWithBlank"</Value>
          </QueryParameter>
          <QueryParameter Name="@vchFacility">
            <Value>=Parameters!vchFacility.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@vchActive">
            <Value>1</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandType>StoredProcedure</CommandType>
        <CommandText>PPsp_WorkCenter_Sel</CommandText>
      </Query>
      <Fields>
        <Field Name="Facility">
          <DataField>Facility</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="WorkCenter">
          <DataField>WorkCenter</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Active">
          <DataField>Active</DataField>
          <rd:TypeName>System.Boolean</rd:TypeName>
        </Field>
