                      <CellContents>
                        <Textbox Name="textbox78">
                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=IIF(DateDiff(DateInterval.Minute,Fields!SchStartTime.Value,Fields!SchEndTime.Value) &lt; 15, "*",nothing)</Value>
                                  <Style>
                                    <Color>Red</Color>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style>
                                <TextAlign>Right</TextAlign>
                              </Style>
                            </Paragraph>
                          </Paragraphs>
                          <rd:DefaultName>textbox78</rd:DefaultName>
                          <ZIndex>10</ZIndex>
                          <ToolTip>=IIF(DateDiff(DateInterval.Minute,Fields!SchStartTime.Value,Fields!SchEndTime.Value) &lt; 15,"Ad hoc shop order", nothing)</ToolTip>
                          <Style>
                            <BackgroundColor>=iif(RowNumber("table1_Group1") Mod 2, "WhiteSmoke", "White")</BackgroundColor>
                            <PaddingLeft>2pt</PaddingLeft>
                            <PaddingRight>2pt</PaddingRight>
                            <PaddingTop>2pt</PaddingTop>
                            <PaddingBottom>2pt</PaddingBottom>
                          </Style>
