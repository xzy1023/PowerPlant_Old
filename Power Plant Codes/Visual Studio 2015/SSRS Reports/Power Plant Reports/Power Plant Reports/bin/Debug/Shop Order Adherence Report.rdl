                          </Paragraphs>
                          <rd:DefaultName>ShopOrder</rd:DefaultName>
                          <ActionInfo>
                            <Actions>
                              <Action>
                                <Drillthrough>
                                  <ReportName>Packaging Log Inquiry</ReportName>
                                  <Parameters>
                                    <Parameter Name="chrFacility">
                                      <Value>=Parameters!vchFacility.Value</Value>
                                    </Parameter>
                                    <Parameter Name="chrPkgLine">
                                      <Value>=Fields!PackagingLine.Value</Value>
                                    </Parameter>
                                    <Parameter Name="intShopOrder">
                                      <Value>=Fields!ShopOrder.Value</Value>
                                    </Parameter>
                                  </Parameters>
