        </Values>
      </DefaultValue>
      <Prompt>Work Center</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>dsWorkCenter</DataSetName>
          <ValueField>WorkCenter</ValueField>
          <LabelField>Description</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="intReportBy">
      <DataType>Integer</DataType>
      <DefaultValue>
        <Values>
          <Value>1</Value>
        </Values>
      </DefaultValue>
      <Prompt>Report By</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>1</Value>
            <Label>Work Center</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>2</Value>
            <Label>Work Center / Line</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>3</Value>
            <Label>Shift</Label>
          </ParameterValue>
        </ParameterValues>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="chrShowShift">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value>N</Value>
        </Values>
      </DefaultValue>
      <Prompt>Show Shift</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>Y</Value>
            <Label>Yes</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>N</Value>
            <Label>No</Label>
          </ParameterValue>
        </ParameterValues>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="intShiftNoFilter">
