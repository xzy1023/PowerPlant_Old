    <DataSet Name="dsExpCol">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@vchGrpBy">
            <Value>=Parameters!vchGrpBy.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 'Collapse All' as Description, 0 as Value
UNION
SELECT CASE WHEN @vchGrpBy = 'WC' THEN 'Exp. Work Center' ELSE 'Exp. Shift' END as Description , 1 as Value
UNION
SELECT 'Expand All' as Description, 2 as Value</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Value">
          <DataField>Value</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsSummaryType">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@vchGrpBy">
            <Value>=Parameters!vchGrpBy.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@blnSummary">
            <Value>=Parameters!blnSummary.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>Select X.Description, X.Value, X.vchGroupBy, X.blnSummary
From (
SELECT 'Not Available' AS Description, 11 AS Value, 'Shift' as vchGroupBy, 0 as blnSummary
UNION
SELECT 'Not Available' AS Description, 12 AS Value, 'Shift' as vchGroupBy, 1 as blnSummary
UNION
SELECT 'Not Available' AS Description, 13 AS Value, 'WC' as vchGroupBy, 0 as blnSummary
UNION
SELECT 'By Work Center By Shift' AS Description, 1 AS Value, 'WC' as vchGroupBy, 1 as blnSummary
UNION
SELECT 'By Work Center only' AS Description, 2 AS Value, 'WC' as vchGroupBy, 1 as blnSummary) X
Where X.vchGroupBy =@vchGrpBy and X.blnSummary = @blnSummary</CommandText>
      </Query>
      <Fields>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Value">
          <DataField>Value</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="vchGroupBy">
          <DataField>vchGroupBy</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="blnSummary">
          <DataField>blnSummary</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
