    <DataSet Name="dsFacility">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@vchAction">
            <Value>="SelByRegion"</Value>
          </QueryParameter>
          <QueryParameter Name="@vchOrderBy">
            <Value>="Desc"</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandType>StoredProcedure</CommandType>
        <CommandText>PPsp_Facility_Sel</CommandText>
      </Query>
      <Fields>
        <Field Name="Facility">
          <DataField>Facility</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Region">
          <DataField>Region</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ShortDescription">
          <DataField>ShortDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsExpCol">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@vchGrpBy">
            <Value>=Parameters!vchGrpBy.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT 'Collapse All' as Description, 0 as Value
UNION
SELECT CASE WHEN @vchGrpBy = 'WC' THEN 'Exp. Work Center' ELSE 'Exp. Shift' END as Description , 1 as Value
UNION
SELECT 'Expand All' as Description, 2 as Value</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Value">
          <DataField>Value</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
