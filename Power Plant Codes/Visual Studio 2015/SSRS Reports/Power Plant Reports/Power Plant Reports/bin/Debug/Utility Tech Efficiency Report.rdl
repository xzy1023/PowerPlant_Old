    <DataSet Name="dsShift">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@vchAction">
            <Value>="AllShifts"</Value>
          </QueryParameter>
          <QueryParameter Name="@chrFacility">
            <Value>=Parameters!vchFacility.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@vchWorkGroup">
            <Value>="P"</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandType>StoredProcedure</CommandType>
        <CommandText>CPPsp_ShiftIO</CommandText>
      </Query>
