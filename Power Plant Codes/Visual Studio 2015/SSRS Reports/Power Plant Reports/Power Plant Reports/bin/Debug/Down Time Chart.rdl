  <ReportParameters>
    <ReportParameter Name="vchFacility">
      <DataType>String</DataType>
      <Prompt>Facility</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>dsFacility</DataSetName>
          <ValueField>Facility</ValueField>
          <LabelField>Description</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="vchMachineID">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
        <Values>
          <Value xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:nil="true" />
        </Values>
      </DefaultValue>
      <Prompt>Line</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>dsPkgLine</DataSetName>
          <ValueField>EquipmentID</ValueField>
          <LabelField>Description</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="intShiftNoFilter">
      <DataType>Integer</DataType>
      <Nullable>true</Nullable>
      <DefaultValue>
        <Values>
          <Value xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:nil="true" />
        </Values>
      </DefaultValue>
      <Prompt>Shift Filter</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>dsShiftFilter</DataSetName>
          <ValueField>Shift</ValueField>
          <LabelField>Description</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="dteFromProdDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>= DateAdd("d",-1,Today)</Value>
        </Values>
      </DefaultValue>
      <Prompt>From Production Date</Prompt>
    </ReportParameter>
    <ReportParameter Name="dteToProdDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>= DateAdd("d",-1,Today)</Value>
        </Values>
      </DefaultValue>
      <Prompt>To Production Date</Prompt>
    </ReportParameter>
    <ReportParameter Name="intFromShift">
      <DataType>Integer</DataType>
      <DefaultValue>
        <Values>
          <Value>=1</Value>
        </Values>
      </DefaultValue>
      <Prompt>From Shift</Prompt>
      <ValidValues>
