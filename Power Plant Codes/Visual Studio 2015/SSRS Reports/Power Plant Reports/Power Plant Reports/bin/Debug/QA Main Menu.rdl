    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsReportMenuItem">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <CommandText>select * from tblReportMenuItems WHERE MenuName = 'QAT Report' order by [row], [column]</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="MenuName">
          <DataField>MenuName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MenuItemName">
          <DataField>MenuItemName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="URL">
          <DataField>URL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Row">
          <DataField>Row</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="Column">
          <DataField>Column</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="ReportID">
          <DataField>ReportID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsServerName">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <CommandText>SELECT CONVERT(sysname, SERVERPROPERTY(N'servername')) as ServerName</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ServerName">
          <DataField>ServerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsWebSiteItems">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <CommandText>select * from tblReportMenuItems WHERE MenuName = 'QAT Web Sites' order by [row],[column]</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="MenuName">
          <DataField>MenuName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MenuItemName">
          <DataField>MenuItemName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="URL">
          <DataField>URL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Row">
          <DataField>Row</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="Column">
          <DataField>Column</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="ReportID">
          <DataField>ReportID</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsMoreReports">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <CommandText>select count(*) as [count] from tblReportMenuItems WHERE MenuName &lt;&gt; 'Power Plant Report' and MenuName &lt;&gt; 'Power Plant Web Sites'</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="count">
          <DataField>count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
