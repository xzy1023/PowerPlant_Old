  <DataSets>
    <DataSet Name="dsFacility">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@vchAction">
            <Value>="SelByRegion"</Value>
          </QueryParameter>
          <QueryParameter Name="@vchOrderBy">
            <Value>="Desc"</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandType>StoredProcedure</CommandType>
        <CommandText>PPsp_Facility_Sel</CommandText>
      </Query>
      <Fields>
        <Field Name="Facility">
          <DataField>Facility</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Region">
          <DataField>Region</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ShortDescription">
          <DataField>ShortDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsDTReasonCode">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@vchFacility">
            <Value>=Parameters!vchFacility.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@vchMachineSubType">
            <Value>=Parameters!vchMachineSubType.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@bitActive">
            <Value>=Parameters!bitActive.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        tRC.MachineSubType AS [Line Type], tRC.ReasonType, tRT.Description AS [Type Description], tRC.ReasonCode, tRC.Description AS [Code Description], tRC.Active
FROM            tblDTReasonType AS tRT RIGHT OUTER JOIN
                         tblDTReasonCode AS tRC ON tRT.Facility = tRC.Facility AND tRT.MachineType = tRC.MachineType AND 
                         CASE WHEN tRT.MachineSubType &lt;&gt; 'ALL' THEN tRT.MachineSubType ELSE tRC.MachineSubType END = tRC.MachineSubType AND tRT.ReasonType = tRC.ReasonType
WHERE        (tRT.Facility = @vchFacility) AND (tRC.MachineType = 'P') AND (tRC.MachineSubType = @vchMachineSubType) AND (tRC.Active = ISNULL(@bitActive, tRC.Active)) OR
                         (tRT.Facility = @vchFacility) AND (tRC.MachineType = 'P') AND (tRC.Active = ISNULL(@bitActive, tRC.Active)) AND (@vchMachineSubType IS NULL)
ORDER BY [Line Type], tRC.ReasonCode</CommandText>
      </Query>
      <Fields>
        <Field Name="Line_Type">
          <DataField>Line Type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ReasonType">
          <DataField>ReasonType</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="Type_Description">
          <DataField>Type Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ReasonCode">
          <DataField>ReasonCode</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="Code_Description">
          <DataField>Code Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Active">
          <DataField>Active</DataField>
          <rd:TypeName>System.Boolean</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsMachinieSubType">
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@vchFacility">
            <Value>=Parameters!vchFacility.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>Select distinct [MachineSubType] as [LineTypeDescription], MachineSubType as [Line Type] from [tblDTReasonCode]
  WHERE Facility = @vchFacility
  Union SELECT '*ALL',NULL
   order by [LineTypeDescription]</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="LineTypeDescription">
          <DataField>LineTypeDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Line_Type">
          <DataField>Line Type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
