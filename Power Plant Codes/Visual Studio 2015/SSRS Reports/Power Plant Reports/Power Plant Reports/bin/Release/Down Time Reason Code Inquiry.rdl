<?xml version="1.0" encoding="utf-8"?>
<Report xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition">
  <DataSources>
    <DataSource Name="PowerPlant">
      <DataSourceReference>PowerPlant</DataSourceReference>
      <rd:DataSourceID>8e248716-76d3-403a-afc4-6e8f102632e7</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsFacility">
      <Fields>
        <Field Name="Facility">
          <DataField>Facility</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Region">
          <DataField>Region</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ShortDescription">
          <DataField>ShortDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <CommandType>StoredProcedure</CommandType>
        <CommandText>PPsp_Facility_Sel</CommandText>
        <QueryParameters>
          <QueryParameter Name="@vchAction">
            <Value>="SelByRegion"</Value>
          </QueryParameter>
          <QueryParameter Name="@vchOrderBy">
            <Value>="Desc"</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
    <DataSet Name="dsDTReasonCode">
      <Fields>
        <Field Name="Line_Type">
          <DataField>Line Type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ReasonType">
          <DataField>ReasonType</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="Type_Description">
          <DataField>Type Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ReasonCode">
          <DataField>ReasonCode</DataField>
          <rd:TypeName>System.Int16</rd:TypeName>
        </Field>
        <Field Name="Code_Description">
          <DataField>Code Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <CommandText>SELECT        tRC.MachineSubType AS [Line Type], tRC.ReasonType, tRT.Description AS [Type Description], tRC.ReasonCode, tRC.Description AS [Code Description]
FROM            tblDTReasonType AS tRT LEFT OUTER JOIN
                         tblDTReasonCode AS tRC ON tRT.Facility = tRC.Facility AND tRT.MachineType = tRC.MachineType AND tRT.MachineSubType = tRC.MachineSubType AND 
                         tRT.ReasonType = tRC.ReasonType
WHERE        (tRT.Facility = @vchFacility) AND (tRC.MachineType = 'P') AND (tRC.MachineSubType = @vchMachineSubType) AND (tRC.Active = 1) OR
                         (tRT.Facility = @vchFacility) AND (tRC.MachineType = 'P') AND (tRC.Active = 1) AND (@vchMachineSubType IS NULL)
ORDER BY [Line Type], tRC.ReasonCode</CommandText>
        <QueryParameters>
          <QueryParameter Name="@vchFacility">
            <Value>=Parameters!vchFacility.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@vchMachineSubType">
            <Value>=Parameters!vchMachineSubType.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
    </DataSet>
    <DataSet Name="dsMachinieSubType">
      <Fields>
        <Field Name="LineTypeDescription">
          <DataField>LineTypeDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Line_Type">
          <DataField>Line Type</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <CommandText>SELECT MachineSubType as [LineTypeDescription], MachineSubType as [Line Type]  FROM tblDTReasonType WHERE Facility = @vchFacility GROUP BY MachineSubType  Union SELECT 'ALL',NULL ORDER BY LineTypeDescription</CommandText>
        <QueryParameters>
          <QueryParameter Name="@vchFacility">
            <Value>=Parameters!vchFacility.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
