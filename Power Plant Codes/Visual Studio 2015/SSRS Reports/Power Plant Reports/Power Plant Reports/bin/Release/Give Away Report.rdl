                                    </Parameter>
                                    <Parameter Name="intWgtSource">
                                      <Value>99</Value>
                                    </Parameter>
                                    <Parameter Name="vchPackagingLine">
                                      <Value>=iif(isnothing(Parameters!vchPackagingLine.Value) , Fields!DefaultPkgLine.Value,Parameters!vchPackagingLine.Value)</Value>
                                    </Parameter>
                                    <Parameter Name="intShopOrder">
                                      <Value>=Parameters!intShopOrder.Value</Value>
                                    </Parameter>
                                    <Parameter Name="vchOperator">
                                      <Value>=Parameters!vchOperator.Value</Value>
                                    </Parameter>
                                    <Parameter Name="vchItemNumber">
                                      <Value>=Fields!ItemNumber.Value</Value>
                                    </Parameter>
                                  </Parameters>
                                </Drillthrough>
                              </Action>
                            </Actions>
                          </ActionInfo>
