<?xml version="1.0" encoding="utf-8"?>
<Report xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition">
  <DataSources>
    <DataSource Name="PowerPlant">
      <DataSourceReference>PowerPlant</DataSourceReference>
      <rd:DataSourceID>c12e48a8-cafc-43de-81ff-e4c3814ca7ba</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsSessionControl">
      <Fields>
        <Field Name="ComputerName">
          <DataField>ComputerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Operator">
          <DataField>Operator</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LogOnTime">
          <DataField>LogOnTime</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="OverrideShiftNo">
          <DataField>OverrideShiftNo</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Name">
          <DataField>Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <CommandText>SELECT  [ComputerName]
      ,[Operator]
      ,[LogOnTime]
      ,[OverrideShiftNo]
      ,	FirstName + ' ' + LastName as Name
  FROM [mphoipc16\sqlexpress].[localPowerPlant].[dbo].[tblSessionControl] t1
left outer join [mphoipc16\sqlexpress].[localPowerPlant].[dbo].[tblPlantStaff] t2
on t1.[Operator] = t2.staffid</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
    </DataSet>
  </DataSets>
