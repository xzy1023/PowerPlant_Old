  <DataSources>
    <DataSource Name="DynamicsAX">
      <DataSourceReference>DynamicsAX</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>cc0978b8-2f2c-47b3-aaeb-880e9c00cfca</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsInterfaceError">
      <Query>
        <DataSourceName>DynamicsAX</DataSourceName>
        <CommandText>;With cteStg AS
(
	select tStg.DATAAREAID as Company
		,Case tInst.[MPLEGACYSYSTEM] 
			WHEN 0 Then 'iMake'
			WHEN 1 Then 'Probat'
			WHEN 2 Then 'Lotus Notes'
			WHEN 3 Then 'Logility'
			WHEN 4 Then 'Mimi'
			WHEN 5 Then 'Power Plant'
			WHEN 6 Then 'EAM'
			WHEN 7 Then 'Knowledge Lake'
		 END as [Legacy System]	
		,tStg.[MPINTERFACEINSTANCEID] as [INSTANCEID]
		,tInst.[MPINTERFACENUM] as [Interface No]
		,tEnt.[MPINTERFACEENTITYNAME] as [Entity Name]
		,tConn.[MPINTERFACECONNECTIONNAME] as [Connection Name]
		,count(*) as StgErrCount 
	FROM MPINTERFACESTAGINGTABLE tStg
	left outer join [MPINTERFACEINSTANCETABLE] tInst
		on tStg.MPINTERFACEINSTANCEID = tInst.RECID
	left outer join [MPINTERFACEENTITYTABLE] tEnt
		on tInst.MPINTERFACEENTITYID = tEnt.MPINTERFACEENTITYID
	left outer join [MPINTERFACECONNECTIONTABLE] tConn
		on tInst.MPINTERFACECONNECTIONID = tConn.MPINTERFACECONNECTIONID
	where tStg.[MPINTERFACEERROR] = 1
	group by 
	  tStg.[DATAAREAID],
		Case tInst.[MPLEGACYSYSTEM] 
		WHEN 0 Then 'iMake'
		 WHEN 1 Then 'Probat'
		 WHEN 2 Then 'Lotus Notes'
		 WHEN 3 Then 'Logility'
		 WHEN 4 Then 'Mimi'
		 WHEN 5 Then 'Power Plant'
		 WHEN 6 Then 'EAM'
		 WHEN 7 Then 'Knowledge Lake'
		 END
		 ,tInst.[MPINTERFACENUM]
		 ,tEnt.[MPINTERFACEENTITYNAME]
		 ,tConn.[MPINTERFACECONNECTIONNAME]
		 ,tStg.MPINTERFACEINSTANCEID
)

, cteErrLog AS
(
 select tInst.[DATAAREAID] as Company,
 Case tInst.[MPLEGACYSYSTEM] 
		WHEN 0 Then 'iMake'
		 WHEN 1 Then 'Probat'
		 WHEN 2 Then 'Lotus Notes'
		 WHEN 3 Then 'Logility'
		 WHEN 4 Then 'Mimi'
		 WHEN 5 Then 'Power Plant'
		 WHEN 6 Then 'EAM'
		 WHEN 7 Then 'Knowledge Lake'
		 END as [Legacy System]	
		 ,tInst.[MPINTERFACENUM] as [Interface No]
		 ,tEnt.[MPINTERFACEENTITYNAME] as [Entity Name]
		 ,tConn.[MPINTERFACECONNECTIONNAME] as [Connection Name]
		 ,tErr.MPINTERFACEINSTANCEID as [INSTANCEID]
		 ,count(*) as [Error Count]

  FROM [MPINTERFACEERRORLOG] tErr
  left outer join [MPINTERFACEINSTANCETABLE] tInst
  on tErr.MPINTERFACEINSTANCEID = tInst.RECID
  left outer join [MPINTERFACEENTITYTABLE] tEnt
  on tInst.MPINTERFACEENTITYID = tEnt.MPINTERFACEENTITYID
  left outer join [MPINTERFACECONNECTIONTABLE] tConn
  on tInst.MPINTERFACECONNECTIONID = tConn.MPINTERFACECONNECTIONID

  group by
  tInst.[DATAAREAID],
  Case tInst.[MPLEGACYSYSTEM] 
		WHEN 0 Then 'iMake'
		 WHEN 1 Then 'Probat'
		 WHEN 2 Then 'Lotus Notes'
		 WHEN 3 Then 'Logility'
		 WHEN 4 Then 'Mimi'
		 WHEN 5 Then 'Power Plant'
		 WHEN 6 Then 'EAM'
		 WHEN 7 Then 'Knowledge Lake'
		 END
		 ,tInst.[MPINTERFACENUM]
		 ,tEnt.[MPINTERFACEENTITYNAME]
		 ,tConn.[MPINTERFACECONNECTIONNAME]
		 ,tErr.MPINTERFACEINSTANCEID
	 ,tConn.[MPINTERFACECONNECTIONNAME]

		 )

Select IsNULL(cteErrLog.Company,cteStg.Company) as Company
	,IsNULL(cteErrLog.[Legacy System],ctestg.[Legacy System]) as [Legacy System]
	,IsNULL(cteErrLog.[Interface No],ctestg.[Interface No]) as [Interface No]
	,IsNULL(cteErrLog.[Entity Name],ctestg.[Entity Name]) as [Entity Name]
	,IsNULL(cteErrLog.[Connection Name],ctestg.[Connection Name]) as [Connection Name]
	,ISNULL(cteErrLog.[Error Count],0) as [Error Log Count]
	,ISNULL(cteStg.StgErrCount,0) as [Staging Error Count]
	from cteErrLog
	full join cteStg 
	on cteStg.INSTANCEID = cteErrlog.INSTANCEID
	order by ISNULL(cteErrLog.[Error Count],0) desc</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="Company">
          <DataField>Company</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Legacy_System">
          <DataField>Legacy System</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Interface_No">
          <DataField>Interface No</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Entity_Name">
          <DataField>Entity Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Connection_Name">
          <DataField>Connection Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Error_Log_Count">
          <DataField>Error Log Count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="Staging_Error_Count">
          <DataField>Staging Error Count</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
  <rd:ReportID>f8c72e25-48a4-4203-98ca-417edd35d9a1</rd:ReportID>
