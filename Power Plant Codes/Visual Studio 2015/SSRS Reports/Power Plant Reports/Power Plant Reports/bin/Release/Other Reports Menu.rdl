    <DataSet Name="dsServerName">
      <Fields>
        <Field Name="ServerName">
          <DataField>ServerName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
      <Query>
        <DataSourceName>PowerPlant</DataSourceName>
        <CommandText>SELECT CONVERT(sysname, SERVERPROPERTY(N'servername')) as ServerName</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
