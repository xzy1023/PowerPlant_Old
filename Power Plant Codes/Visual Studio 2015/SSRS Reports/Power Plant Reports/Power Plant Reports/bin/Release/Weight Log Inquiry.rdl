          <DataSetName>dsFacility</DataSetName>
          <ValueField>Facility</ValueField>
          <LabelField>Description</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="dteFromProdDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=DateAdd("d",-1,Today)</Value>
        </Values>
      </DefaultValue>
      <Prompt>From Date</Prompt>
    </ReportParameter>
    <ReportParameter Name="dteToProdDate">
      <DataType>DateTime</DataType>
      <DefaultValue>
        <Values>
          <Value>=DateAdd("d",-1,Today)</Value>
        </Values>
      </DefaultValue>
      <Prompt>To Date</Prompt>
    </ReportParameter>
    <ReportParameter Name="intFromShift">
      <DataType>Integer</DataType>
      <DefaultValue>
        <Values>
          <Value>=1</Value>
        </Values>
      </DefaultValue>
      <Prompt>From Shift</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>dsShift</DataSetName>
          <ValueField>ShiftSequence</ValueField>
          <LabelField>Description</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="intToShift">
      <DataType>Integer</DataType>
      <DefaultValue>
        <DataSetReference>
          <DataSetName>dsMaxShiftNo</DataSetName>
          <ValueField>MaxShiftNo</ValueField>
        </DataSetReference>
      </DefaultValue>
      <Prompt>To Shift</Prompt>
      <ValidValues>
        <DataSetReference>
          <DataSetName>dsShift</DataSetName>
          <ValueField>ShiftSequence</ValueField>
          <LabelField>Description</LabelField>
        </DataSetReference>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="intPercentTolerence">
      <DataType>Integer</DataType>
      <DefaultValue>
        <Values>
          <Value>100</Value>
        </Values>
      </DefaultValue>
      <Prompt>% Target Tolerance </Prompt>
    </ReportParameter>
    <ReportParameter Name="intWgtSource">
      <DataType>Integer</DataType>
      <DefaultValue>
        <Values>
          <Value>=99</Value>
        </Values>
      </DefaultValue>
      <Prompt>Weight Source Type</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>0</Value>
            <Label>Auto</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>1</Value>
            <Label>Manual</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>2</Value>
            <Label>Tareweight</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>99</Value>
            <Label>Excl. Tareweight</Label>
          </ParameterValue>
        </ParameterValues>
      </ValidValues>
    </ReportParameter>
