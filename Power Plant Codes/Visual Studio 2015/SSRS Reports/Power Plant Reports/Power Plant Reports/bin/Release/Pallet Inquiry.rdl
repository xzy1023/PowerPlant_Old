    <ReportParameter Name="blnShowReasonCode">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value>="N"</Value>
        </Values>
      </DefaultValue>
      <Prompt>Show Suggested Adj. Reason Code</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>Y</Value>
            <Label>Yes</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>N</Value>
            <Label>No</Label>
          </ParameterValue>
        </ParameterValues>
      </ValidValues>
    </ReportParameter>
    <ReportParameter Name="vchPostiingSts">
      <DataType>String</DataType>
      <DefaultValue>
        <Values>
          <Value>A</Value>
        </Values>
      </DefaultValue>
      <Prompt>Postiing Status</Prompt>
      <ValidValues>
        <ParameterValues>
          <ParameterValue>
            <Value>A</Value>
            <Label>*ALL</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>Y</Value>
            <Label>Posted</Label>
          </ParameterValue>
          <ParameterValue>
            <Value>N</Value>
            <Label>Unposted</Label>
          </ParameterValue>
        </ParameterValues>
      </ValidValues>
