  <Code>Public Shared Function Divide(ByVal Numerator as Double, ByVal Denominator as Double) as Double
 If Denominator = 0 Then
   Return 0
 Else
   Return Numerator/Denominator
 End IF
End Function

Public Shared Function OpenURL(ByVal strURL as String) As String
Return "javascript:void(window.open('" &amp; strURL &amp; "','_blank'))"
End Function
