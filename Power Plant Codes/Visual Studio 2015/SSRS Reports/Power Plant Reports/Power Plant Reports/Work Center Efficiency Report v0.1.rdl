                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=Sum(Round(Fields!StdMachineHrEarnedInUnit.Value,1))</Value>
                                  <Style>
                                    <Format>##,##0.0</Format>
                                  </Style>
