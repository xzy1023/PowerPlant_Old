                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=Avg(Round(Fields!StdUnitPerHr.Value * Fields!NetWeight.Value,0))</Value>
                                  <Style>
                                    <Format>###,##0</Format>
                                  </Style>
                                </TextRun>
                              </TextRuns>
                              <Style />
                            </Paragraph>
                          </Paragraphs>
