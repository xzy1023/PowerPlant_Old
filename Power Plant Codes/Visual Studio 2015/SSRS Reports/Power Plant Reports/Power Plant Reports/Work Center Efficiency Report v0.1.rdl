                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=Sum(Fields!ActRunTime.Value - Fields!PaidRunTime.Value)</Value>
                                  <Style>
                                    <Format>n</Format>
                                  </Style>
