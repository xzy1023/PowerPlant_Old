                          <CanGrow>true</CanGrow>
                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=Avg(Fields!StdWCEfficiency.Value)</Value>
                                  <Style>
                                    <Format>#0.00%</Format>
