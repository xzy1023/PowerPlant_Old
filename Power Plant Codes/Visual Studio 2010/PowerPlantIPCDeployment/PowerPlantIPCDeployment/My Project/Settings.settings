    <Setting Name="strConn" Type="(Connection string)" Scope="Application">
      <DesignTimeValue Profile="(Default)">&lt;?xml version="1.0" encoding="utf-16"?&gt;
&lt;SerializableConnectionString xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema"&gt;
  &lt;ConnectionString&gt;Data Source=MPHOPP01;Initial Catalog=PowerPlant_Deployment;Persist Security Info=True;User ID=mpo;Password=mpopwd$1&lt;/ConnectionString&gt;
  &lt;ProviderName&gt;System.Data.SqlClient&lt;/ProviderName&gt;
&lt;/SerializableConnectionString&gt;</DesignTimeValue>
      <Value Profile="(Default)">Data Source=MPHOPP01;Initial Catalog=PowerPlant_Deployment;Persist Security Info=True;User ID=mpo;Password=mpopwd$1</Value>
    </Setting>
    <Setting Name="strDftRegSubKeyPath" Type="System.String" Scope="User">
