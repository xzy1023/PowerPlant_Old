    <Setting Name="strDownTimeFiles" Type="System.String" Scope="User">
      <Value Profile="(Default)">DownTime.exe</Value>
    </Setting>
    <Setting Name="strSourceFolder" Type="System.String" Scope="User">
      <Value Profile="(Default)">C:\Users\leebong\OneDrive - Mother Parkers Tea and Coffee\Home\PowerPlant Archives\Power Plant\V6.40 OLSOV\DeploymentObjects</Value>
