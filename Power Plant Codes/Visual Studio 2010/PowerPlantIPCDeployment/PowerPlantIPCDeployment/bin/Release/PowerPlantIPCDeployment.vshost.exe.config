<?xml version="1.0"?>
<configuration>
    <configSections>
        <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
            <section name="PowerPlantIPCDeployment.MySettings" type="System.Configuration.ClientSettingsSection, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false"/>
        </sectionGroup>
    </configSections>
    <connectionStrings>
        <add name="PowerPlantIPCDeployment.MySettings.strConn" connectionString="Data Source=MPHOPP01;Initial Catalog=PowerPlant_Deployment;Persist Security Info=True;User ID=mpo;Password=mpopwd$1"
            providerName="System.Data.SqlClient" />
    </connectionStrings>
    <system.diagnostics>
        <sources>
            <!-- This section defines the logging configuration for My.Application.Log -->
            <source name="DefaultSource" switchName="DefaultSwitch">
                <listeners>
                    <add name="FileLog"/>
                    <!-- Uncomment the below section to write to the Application Event Log -->
                    <!--<add name="EventLog"/>-->
                </listeners>
            </source>
        </sources>
        <switches>
            <add name="DefaultSwitch" value="Information"/>
        </switches>
        <sharedListeners>
            <add name="FileLog" type="Microsoft.VisualBasic.Logging.FileLogTraceListener, Microsoft.VisualBasic, Version=8.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a, processorArchitecture=MSIL" initializeData="FileLogWriter"/>
            <!-- Uncomment the below section and replace APPLICATION_NAME with the name of your application to write to the Application Event Log -->
            <!--<add name="EventLog" type="System.Diagnostics.EventLogTraceListener" initializeData="APPLICATION_NAME"/> -->
        </sharedListeners>
    </system.diagnostics>
    <userSettings>
        <PowerPlantIPCDeployment.MySettings>
            <setting name="strPowerPlantFolder" serializeAs="String">
                <value>C$\PowerPlant\PowerPlant</value>
            </setting>
            <setting name="strPowerPlantFiles" serializeAs="String">
                <value>Palletizer.exe,PowerPlant.exe</value>
            </setting>
            <setting name="strDownTimeFolder" serializeAs="String">
                <value>C$\PowerPlant\DownTime</value>
            </setting>
            <setting name="strIPCInitialPgmFolder" serializeAs="String">
                <value>C$\PowerPlant\IPCInitialPgm</value>
            </setting>
            <setting name="strIPCInitialPgmFiles" serializeAs="String">
                <value>IPCInitialPgm.exe.config</value>
            </setting>
            <setting name="strLogFile" serializeAs="String">
                <value>C:\DeploymentLog\</value>
            </setting>
            <setting name="strDftRegSubKeyPath" serializeAs="String">
                <value>Software\ODBC\ODBC.INI\ServerPowerPlant</value>
            </setting>
            <setting name="strDftRegKeyName" serializeAs="String">
                <value>Server</value>
            </setting>
            <setting name="strDftNewRegValue" serializeAs="String">
                <value>MPSPPP01</value>
            </setting>
            <setting name="strDftProbatClientSourceFolder" serializeAs="String">
                <value>C:\ProbatClient</value>
            </setting>
            <setting name="strDftProbatClientTargetFolder" serializeAs="String">
                <value>C$\ProbatClient</value>
            </setting>
            <setting name="strDftProbatFiles" serializeAs="String">
                <value />
            </setting>
            <setting name="strDftCfgProbatRegistryBatchFile" serializeAs="String">
                <value>C:\ProbatClient\ConfigureProbatClientRegistry.bat</value>
            </setting>
            <setting name="strDownTimeFiles" serializeAs="String">
                <value>DownTime.exe</value>
            </setting>
            <setting name="strSourceFolder" serializeAs="String">
                <value>C:\Users\leebong\OneDrive - Mother Parkers Tea and Coffee\Home\PowerPlant Archives\Power Plant\V6.40 OLSOV\DeploymentObjects</value>
            </setting>
            <setting name="strSourceFolderSQL" serializeAs="String">
                <value>C:\Users\leebong\OneDrive - Mother Parkers Tea and Coffee\Home\PowerPlant Archives\Power Plant\V6.40 OLSOV\Changes on Server</value>
            </setting>
            <setting name="strWCFFolder" serializeAs="String">
                <value>C$\PowerPlant\PPWCFService</value>
            </setting>
            <setting name="strWCFFiles" serializeAs="String">
                <value>PPWCFService.dll</value>
            </setting>
            <setting name="strTCPFolder" serializeAs="String">
                <value>C$\PowerPlant\PPTCPServer</value>
            </setting>
            <setting name="strTCPFiles" serializeAs="String">
                <value>PPTCPServer.exe</value>
            </setting>
        </PowerPlantIPCDeployment.MySettings>
    </userSettings>
<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0,Profile=Client"/></startup></configuration>
