<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <configSections>
    <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
      <section name="PowerPlant.My.MySettings" type="System.Configuration.ClientSettingsSection, System, Version=2.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
    </sectionGroup>
  </configSections>
  <connectionStrings>
    <add name="PowerPlant.My.MySettings.ServerPowerPlantCnnStr" connectionString="Data Source=MPHOPP02;Initial Catalog=PowerPlantCUSP_UA;Integrated Security=True;Connect Timeout=7"
      providerName="System.Data.SqlClient" />
    <add name="PowerPlant.My.MySettings.LocalPowerPlantCnnStr" connectionString="Data Source=.\SQLEXPRESS;Initial Catalog=LocalPowerPlant;Integrated Security=True"
      providerName="System.Data.SqlClient" />
    <add name="PowerPlantEntities" connectionString="metadata=res://*/Models.PowerPlantModels.csdl|res://*/Models.PowerPlantModels.ssdl|res://*/Models.PowerPlantModels.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=MPHOPP02;initial catalog=PowerPlantCUSP_UA;integrated security=True;connect timeout=7;MultipleActiveResultSets=True;App=EntityFramework&quot;"
      providerName="System.Data.EntityClient" />
    <add name="PowerPlantLocalEntities" connectionString="metadata=res://*/Models.PowerPlantLocalModels.csdl|res://*/Models.PowerPlantLocalModels.ssdl|res://*/Models.PowerPlantLocalModels.msl;provider=System.Data.SqlClient;provider connection string=&quot;data source=.\SQLEXPRESS;initial catalog=LocalPowerPlant;integrated security=True;MultipleActiveResultSets=True;App=EntityFramework&quot;"
      providerName="System.Data.EntityClient" />
  </connectionStrings>
  <system.diagnostics>
    <sources>
      <!-- This section defines the logging configuration for My.Application.Log -->
      <source name="DefaultSource" switchName="DefaultSwitch">
        <listeners>
          <add name="FileLog" />
          <!-- Uncomment the below section to write to the Application Event Log -->
          <!--<add name="EventLog"/>-->
        </listeners>
      </source>
    </sources>
    <switches>
      <add name="DefaultSwitch" value="Information" />
    </switches>
    <sharedListeners>
      <add name="FileLog" type="Microsoft.VisualBasic.Logging.FileLogTraceListener, Microsoft.VisualBasic, Version=8.0.0.0, Culture=neutral, PublicKeyToken=b03f5f7f11d50a3a, processorArchitecture=MSIL" initializeData="FileLogWriter" />
      <!-- Uncomment the below section and replace APPLICATION_NAME with the name of your application to write to the Application Event Log -->
      <!--<add name="EventLog" type="System.Diagnostics.EventLogTraceListener" initializeData="APPLICATION_NAME"/> -->
    </sharedListeners>
  </system.diagnostics>
  <userSettings>
    <PowerPlant.My.MySettings>
      <setting name="strDownTime" serializeAs="String">
        <value>C:\PowerPlant\DownTime\DownTime.exe</value>
      </setting>
      <setting name="gstrSerialTouchScreenPgm" serializeAs="String">
        <value>C:\Program Files\TouchScreen [XP] V.6.7.COM\TSWXPCCP.exe</value>
      </setting>
      <setting name="gintTimeDelayToCheckPalletRepost" serializeAs="String">
        <value>300</value>
      </setting>
      <setting name="gstrUSBTouchScreenPgm" serializeAs="String">
        <value>C:\Program Files\Elo TouchSystems\EloVa.exe</value>
      </setting>
      <setting name="gintCaseCountInterval" serializeAs="String">
        <value>5000</value>
      </setting>
      <setting name="gintMainScreenTimerInterval" serializeAs="String">
        <value>4000</value>
      </setting>
      <setting name="gstrUSBTouchScreenPgm2" serializeAs="String">
        <value>C:\Program Files (x86)\TouchKit\xAuto4PtsCal.exe</value>
      </setting>
      <setting name="strPPTCPServer" serializeAs="String">
        <value>C:\PowerPlant\PPTCPServer\PPTCPServer.exe</value>
      </setting>
    </PowerPlant.My.MySettings>
  </userSettings>
  <startup>
    <supportedRuntime version="v2.0.50727" />
  </startup>
</configuration>